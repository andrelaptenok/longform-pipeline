{
  "name": "longform-pipeline",
  "version": "0.1.0",
  "private": true,
  "description": "Pipeline for generating long, structured texts with a rubric-calibrated eval system.",
  "keywords": [
    "llm",
    "prompt-engineering",
    "evals",
    "llm-as-judge",
    "rag",
    "typescript"
  ],
  "license": "MIT",
  "author": "Andrei Laptsenak <andrelaptenok@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrelaptenok/longform-pipeline.git"
  },
  "bugs": {
    "url": "https://github.com/andrelaptenok/longform-pipeline/issues"
  },
  "homepage": "https://github.com/andrelaptenok/longform-pipeline#readme",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "gen": "tsx src/cli.ts",
    "eval": "tsx evals/runners/run.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "yaml": "^2.6.1"
  }
}
